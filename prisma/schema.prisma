// Career Copilot — Prisma schema
// Database: PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Enums ============

enum Role {
  USER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum ExperienceLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum ApplicationStatus {
  APPLIED
  IN_REVIEW
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum InterviewQuestionType {
  TECHNICAL
  HR
  BEHAVIORAL
  SCENARIO
}

enum AIAnalysisKind {
  RESUME_PARSE
  RESUME_JOB_MATCH
  RESUME_JD_ANALYZE
  CAREER_READINESS
  INTERVIEW_EVALUATE
}

// ============ Auth ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  refreshTokens     RefreshToken[]
  resumes           Resume[]
  savedJobs         SavedJob[]
  applications      JobApplication[]
  interviewSessions InterviewSession[]
  aiAnalyses        AIAnalysis[]
  careerReports     CareerReport[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============ Catalog ============

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String?
  website     String?
  description String?  @db.Text
  industry    String?
  size        String?
  hqLocation  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs Job[]

  @@index([industry])
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  category  String?
  createdAt DateTime @default(now())

  jobs    JobSkill[]
  resumes ResumeSkill[]

  @@index([category])
}

model Job {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  companyId        String
  location         String
  workMode         WorkMode        @default(ONSITE)
  jobType          JobType         @default(FULL_TIME)
  experienceLevel  ExperienceLevel @default(MID)
  experienceMin    Int             @default(0)
  experienceMax    Int             @default(10)
  salaryMin        Int?
  salaryMax        Int?
  currency         String          @default("INR")
  description      String          @db.Text
  responsibilities String[]
  benefits         String[]
  active           Boolean         @default(true)
  postedAt         DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills       JobSkill[]
  savedBy      SavedJob[]
  applications JobApplication[]

  @@index([companyId])
  @@index([workMode])
  @@index([jobType])
  @@index([experienceLevel])
  @@index([active, postedAt])
}

model JobSkill {
  jobId    String
  skillId  String
  required Boolean @default(true)
  weight   Int     @default(1)

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@index([skillId])
}

model SavedJob {
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([userId, jobId])
  @@index([jobId])
}

model JobApplication {
  id        String            @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(APPLIED)
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([status])
}

// ============ Resume ============

model Resume {
  id            String   @id @default(cuid())
  userId        String
  fileName      String
  fileSize      Int
  rawText       String   @db.Text
  // Structured profile produced by AI parse (skills, experience, education, projects, certifications)
  parsedProfile Json
  summary       String?  @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills ResumeSkill[]

  @@index([userId, active])
}

model ResumeSkill {
  resumeId    String
  skillId     String
  proficiency Int    @default(50) // 0..100
  years       Float  @default(0)
  source      String @default("ai")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([resumeId, skillId])
  @@index([skillId])
}

// ============ Interview ============

model InterviewSession {
  id           String   @id @default(cuid())
  userId       String
  jobId        String?
  resumeId     String?
  jobTitle     String?
  jdSnippet    String?  @db.Text
  status       String   @default("active") // active | completed
  overallScore Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions InterviewQuestion[]

  @@index([userId])
}

model InterviewQuestion {
  id        String                @id @default(cuid())
  sessionId String
  order     Int
  type      InterviewQuestionType
  prompt    String                @db.Text
  rubric    String?               @db.Text
  createdAt DateTime              @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer  InterviewAnswer?

  @@unique([sessionId, order])
}

model InterviewAnswer {
  id              String   @id @default(cuid())
  questionId      String   @unique
  answer          String   @db.Text
  score           Int // 0..100
  accuracy        Int
  communication   Int
  completeness    Int
  relevance       Int
  strengths       String[]
  weaknesses      String[]
  suggestedAnswer String   @db.Text
  createdAt       DateTime @default(now())

  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ============ AI Analyses & Reports ============

model AIAnalysis {
  id        String         @id @default(cuid())
  userId    String
  kind      AIAnalysisKind
  // Free-form inputs/outputs for traceability of any AI run
  input     Json
  output    Json
  model     String?
  tokensIn  Int?
  tokensOut Int?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, createdAt])
}

model CareerReport {
  id                 String   @id @default(cuid())
  userId             String
  resumeId           String?
  careerScore        Int
  employabilityScore Int
  atsReadiness       Int
  interviewReadiness Int
  skillReadiness     Int
  improvementPlan    Json
  actionItems        Json
  recommendations    Json
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
