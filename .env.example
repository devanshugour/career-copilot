# Database — Neon (https://neon.tech) free tier recommended
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (NextAuth v5)
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude — REQUIRED
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Optional model overrides — leave commented to use the snappy defaults.
# ANTHROPIC_MODEL_FAST   → used for job matching, interview Q gen + answer eval, career readiness.
# ANTHROPIC_MODEL_SMART  → used for resume PDF parsing and full JD analysis.
# ANTHROPIC_MODEL_FAST="claude-haiku-4-5"
# ANTHROPIC_MODEL_SMART="claude-sonnet-4-6"
